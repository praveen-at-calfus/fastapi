# Copy this file to `.env` and adjust values. `.env` is gitignored (never
# committed) so real credentials stay off version control. Docker Compose
# reads `.env` automatically and substitutes these values into the compose file.

# --- Postgres credentials (used by the db service) ---
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=tasks

# --- Port the Postgres container is published on the host (for DBeaver) ---
# If host port 5432 is already in use (e.g. a native Postgres running on your
# machine), change this to a free port such as 5433 and connect DBeaver there.
POSTGRES_PORT=5432
